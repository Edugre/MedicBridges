# MedicBridges frontend -- environment configuration
#
# Copy to `.env` and adjust as needed. All client-exposed vars MUST be prefixed
# with VITE_ (Vite only exposes those to the browser).

# Base URL for the FastAPI backend.
#
# Leave EMPTY in local dev: requests use same-origin relative paths (e.g.
# `/api/v1/resources/nearby`) and the Vite dev server proxies them to the API
# (see VITE_API_PROXY_TARGET / vite.config.js).
#
# In production, set this to the deployed API origin, e.g.
#   VITE_API_BASE_URL="https://api.medicbridges.org"
VITE_API_BASE_URL=""

# Where the Vite dev proxy forwards /api and /health (dev only).
VITE_API_PROXY_TARGET="http://localhost:8000"
