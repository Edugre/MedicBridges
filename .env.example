# MedicBridges v2 -- environment configuration
#
# Decision D1: v2 is built in a BRAND-NEW Supabase project for clean isolation.
# Provision the new project, then fill these in and copy to `.env`.

# Base project URL (with or without a trailing /rest/v1 -- both are handled).
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Service-role key: REQUIRED for ETL + geocoding. It bypasses RLS so transforms,
# staging loads, and etl_run logging all work. Keep this secret; never ship to
# the frontend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Anon (publishable) key: used by the read-only frontend AND the FastAPI public
# read routes (RLS grants public SELECT on the curated tables/views).
SUPABASE_ANON_KEY="your-anon-key"

# --- FastAPI service (api/) ---
# Secret for the /api/v1/admin/* ingestion-monitoring routes (X-Admin-Key header).
ADMIN_API_KEY="generate-a-long-random-string"

# Medication reference source. 'cache' = Postgres-backed typeahead (recommended),
# seeded by scripts/etl/etl_medications.py.
MED_DATA_SOURCE="cache"

# Google Geocoding API key: ONLY needed for
# `scripts/geocode/run_geocode_queue.py --provider google`. The default
# nominatim provider needs no key. Create/restrict the key in Google Cloud
# Console (APIs & Services > Credentials) and enable the "Geocoding API".
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# CORS: comma-separated allowed origins for the frontend, or '*' for all.
CORS_ORIGINS="*"

# Cloudflare Turnstile secret key: verifies the captcha on the public
# POST /api/v1/reports endpoint. Leave EMPTY to disable captcha in local dev.
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile and
# pair this with the frontend's VITE_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=""
